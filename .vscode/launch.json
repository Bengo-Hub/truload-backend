{
  "version": "0.2.0",
  "configurations": [
    {
      "name": ".NET Core Launch (IIS Express)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/bin/Debug/net10.0/truload-backend.dll",
      "args": [],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      },
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "Now listening on:\\s+(https?://\\S+)"
      },
      "launchBrowser": {
        "enabled": true,
        "args": "${autoUrl}/swagger"
      },
      "dotnetRunMessages": true,
      "launchSettingsProfile": "IIS Express"
    }
  ]
}