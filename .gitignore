## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
build/
Logs/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/

# Visual Studio
.vs/
*.userprefs

# Rider
.idea/
*.sln.iml

# NuGet
*.nupkg
*.snupkg
**/packages/*
!**/packages/build/

# Environment files
.env
.env.*
!.env.example

# Logs
*.log

# OS
.DS_Store
Thumbs.db

# Backup files
*.bak
KubeSecrets/*.bak

# Temporary files
*.tmp
*.temp
/Logs

# E2E test results
Tests/e2e/compliancee2e/test_credentials.py
Tests/e2e/compliancee2e/TEST_RESULTS.md
Tests/e2e/compliancee2e/TEST_SUMMARY.md
Tests/e2e/compliancee2e/TEST_LOGS.md
Tests/e2e/compliancee2e/TEST_ERRORS.md
Tests/e2e/compliancee2e/TEST_WARNINGS.md
Tests/e2e/compliancee2e/TEST_INFO.md
Tests/e2e/compliancee2e/TEST_DEBUG.md
Tests/e2e/compliancee2e/TEST_TRACE.md
Tests/e2e/compliancee2e/TEST_CRITICAL.md
Tests/e2e/compliancee2e/TEST_FATAL.md
Tests/e2e/test_credentials.py
Tests/e2e/.truload_auth_cache.json
