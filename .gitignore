## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
build/
Logs/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/

# Visual Studio
.vs/
*.userprefs

# Rider
.idea/
*.sln.iml

# NuGet
*.nupkg
*.snupkg
**/packages/*
!**/packages/build/

# Environment files
.env
.env.*
!.env.example

# Logs
*.log

# OS
.DS_Store
Thumbs.db

# Backup files
*.bak
KubeSecrets/*.bak

# Temporary files
*.tmp
*.temp
/Logs

# E2E test results
Tests/e2e/compliancee2e/test_credentials.py
Tests/e2e/compliancee2e/TEST_RESULTS.md
Tests/e2e/compliancee2e/TEST_SUMMARY.md
Tests/e2e/compliancee2e/TEST_LOGS.md
Tests/e2e/compliancee2e/TEST_ERRORS.md
Tests/e2e/compliancee2e/TEST_WARNINGS.md
Tests/e2e/compliancee2e/TEST_INFO.md
Tests/e2e/compliancee2e/TEST_DEBUG.md
Tests/e2e/compliancee2e/TEST_TRACE.md
Tests/e2e/compliancee2e/TEST_CRITICAL.md
Tests/e2e/compliancee2e/TEST_FATAL.md
Tests/e2e/test_credentials.py
Tests/e2e/.truload_auth_cache.json

# Pesaflow / eCitizen e2e: credentials, tokens, and generated request/response logs
# NEVER commit these — they contain live API keys, secrets, and bearer tokens
Tests/e2e/.env.production
Tests/e2e/.env.staging
Tests/e2e/.env.*.local
Tests/e2e/.pesaflow_token_cache.json
Tests/e2e/.truload_auth_cache.json
Tests/e2e/.expired_test.json
Tests/e2e/oauth_request_*.json
Tests/e2e/oauth_response_*.json
Tests/e2e/pesaflow_local_invoice_*.json
Tests/e2e/pesaflow_last_post_payload.json
Tests/e2e/pesaflow_api_test.md
Tests/e2e/pesaflow_invoice_e2e.md
Tests/e2e/pesaflow_callback_reconciliation_e2e.md
# Root-level stray artifacts
.pesaflow_token_cache.json
oauth_test_run.json
oauth_request_*.json
oauth_response_*.json
